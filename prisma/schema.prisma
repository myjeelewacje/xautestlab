generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
model PollOption { id String @id @default(cuid()) label String sortOrder Int @unique active Boolean @default(true) votes PollVote[] createdAt DateTime @default(now()) }
model PollVote { id String @id @default(cuid()) optionId String option PollOption @relation(fields:[optionId],references:[id],onDelete:Cascade) customModel String? ipHash String cookieHash String @unique createdAt DateTime @default(now()) @@index([ipHash]) }
model InterestRegistration { id String @id @default(cuid()) email String @unique name String? preferredModel String contactHandle String? consent Boolean contacted Boolean @default(false) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model VisitorQuestion { id String @id @default(cuid()) displayName String? question String answer String? approved Boolean @default(false) published Boolean @default(false) rejected Boolean @default(false) ipHash String createdAt DateTime @default(now()) updatedAt DateTime @updatedAt @@index([approved,published,createdAt]) }
model SiteSetting { key String @id value String updatedAt DateTime @updatedAt }
model AdminActionLog { id String @id @default(cuid()) action String targetId String? createdAt DateTime @default(now()) }
